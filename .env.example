# ============================================
# Arc Treasury — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Frontend (Vite, prefix VITE_) ---

# Supabase (frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Fixer.io exchange rate API (frontend)
VITE_FIXER_API_KEY=your-fixer-api-key

# --- Contracts (Hardhat scripts, deploy, setBaseAPY, etc.) ---

# Owner wallet private key (deploys, upgrades, setBaseAPY)
PRIVATE_KEY=0x_your_owner_private_key

# Operator wallet (auto-convert USDC->USYC, rebalance, APY auto-sync)
PRIVATE_KEY_OPERATOR=0x_your_operator_private_key

# Operator address (used in deploy scripts as TREASURY_OPERATOR)
TREASURY_OPERATOR=0xYourOperatorAddress

# Infura API key (for Sepolia RPC in bridge monitoring)
INFURA_API=your-infura-project-id

# --- Telegram Bot (railway-bot/telegramBot.ts) ---

# Treasury bot (@usyc_bot)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Fixer.io (bot uses same key, no VITE_ prefix)
FIXER_API_KEY=your-fixer-api-key

# Supabase (bot uses these names, no VITE_ prefix)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# --- Twitter OAuth (user registration + repost verification) ---
# Used by api/twitter.ts for Twitter connect + 1.5x points multiplier

ClientID=your-twitter-oauth-client-id
ClientSecret=your-twitter-oauth-client-secret
TWITTER_REQUIRED_TWEET_ID=your-tweet-id-for-repost-check

# --- Ponder Indexer ---
# Uses VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY from above
# No additional vars needed — RPC is hardcoded in ponder.config.ts

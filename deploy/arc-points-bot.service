[Unit]
Description=Arc Treasury Points Bot (Twitter engagement tracking)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/arc-treasury/bots
ExecStart=/usr/bin/node points-bot-tw.cjs --daemon --interval=60
Restart=on-failure
RestartSec=10
Environment=NODE_ENV=production
EnvironmentFile=/opt/arc-treasury/.env

[Install]
WantedBy=multi-user.target
